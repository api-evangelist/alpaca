{
  "opencollection": "1.0.0",
  "info": {
    "name": "OAuth API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Stock Pricing Data API",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Bars",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://data.alpaca.markets/v2/v2/stocks/:symbol/bars",
            "headers": [
              {
                "name": "Apca-Api-Key-Id",
                "value": "{{APCA_API_KEY_ID}}"
              },
              {
                "name": "Apca-Api-Secret-Key",
                "value": "{{APCA_API_SECRET_KEY}}"
              }
            ],
            "params": [
              {
                "name": "symbol",
                "value": "",
                "type": "path"
              },
              {
                "name": "start",
                "value": "2020-04-01T0:00:00Z",
                "type": "query",
                "description": "Filter data equal to or after this time in RFC-3339 format. Fractions of a second are not accepted."
              },
              {
                "name": "end",
                "value": "2021-08-26T11:00:00Z",
                "type": "query",
                "description": "Filter data equal to or before this time in RFC-3339 format. Fractions of a second are not accepted."
              },
              {
                "name": "timeframe",
                "value": "1Min",
                "type": "query",
                "description": "Timeframe for the aggregation. Values are customizeable, frequently used examples: 1Min, 15Min, 1Hour, 1Day."
              }
            ]
          },
          "docs": "The bars API returns aggregate historical data for the requested securities"
        },
        {
          "info": {
            "name": "Trades",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://data.alpaca.markets/v2/v2/stocks/:symbol/trades",
            "headers": [
              {
                "name": "Apca-Api-Key-Id",
                "value": "{{APCA_API_KEY_ID}}"
              },
              {
                "name": "Apca-Api-Secret-Key",
                "value": "{{APCA_API_SECRET_KEY}}"
              }
            ],
            "params": [
              {
                "name": "start",
                "value": "2020-04-01T0:00:00Z",
                "type": "query",
                "description": "Filter data equal to or after this time in RFC-3339 format. Fractions of a second are not accepted."
              },
              {
                "name": "end",
                "value": "2021-08-26T11:00:00Z",
                "type": "query",
                "description": "Filter data equal to or before this time in RFC-3339 format. Fractions of a second are not accepted."
              },
              {
                "name": "symbol",
                "value": "AAPL",
                "type": "path",
                "description": "The symbol to query for"
              }
            ]
          },
          "docs": "The Trades API provides historcial trade data for a given ticker symbol on a specified date. Returns trades for the queried stock signal."
        }
      ]
    }
  ],
  "bundled": true
}